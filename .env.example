# --- Job Application App environment ---------------------------------------
#
# Copy this file to `.env` and fill in the values before `docker compose up`.
# `.env` is gitignored; `.env.example` is the canonical documented shape.

# Master encryption key for the Secrets vault (Fernet / AES128-CBC + HMAC).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The app FAILS FAST on startup if this is missing or malformed.
# Rotating this key makes previously stored secrets unreadable (no rotation tool in v1).
FERNET_KEY=

# Container timezone. Drives the local-midnight reset of RateLimitCounter rows
# and APScheduler cron triggers. Use an IANA zone name (e.g. America/Los_Angeles).
TZ=America/Los_Angeles

# Host interface the app binds to. 0.0.0.0 = LAN-reachable (default), 127.0.0.1 = loopback only.
BIND_ADDRESS=0.0.0.0
