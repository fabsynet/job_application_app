<dialog open class="review-confirm-modal" id="review-confirm-modal">
  <article>
    <header>
      <h3>Approve {{ job_ids|length }} jobs?</h3>
    </header>
    <ul>
      {% for j in jobs %}
      <li>{{ j.company }} &mdash; {{ j.title }}</li>
      {% endfor %}
    </ul>
    <form hx-post="/review/approve-batch"
          hx-target="#review-table"
          hx-swap="innerHTML"
          hx-on::after-request="document.getElementById('modal').innerHTML = ''">
      {% for jid in job_ids %}
      <input type="hidden" name="job_ids" value="{{ jid }}">
      {% endfor %}
      <button type="submit">Approve {{ job_ids|length }}</button>
      <button type="button"
              onclick="document.getElementById('modal').innerHTML = ''">Cancel</button>
    </form>
  </article>
</dialog>
