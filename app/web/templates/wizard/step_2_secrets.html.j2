{% extends "wizard/_layout.html.j2" %}
{% block wizard_content %}
<section>
  <h4>API keys and email credentials</h4>
  <p>
    All fields are <strong>optional at this step</strong> and are encrypted
    at rest with your <code>FERNET_KEY</code> before being written to
    <code>data/app.db</code>. Leave any of them blank now and set them later
    from the Settings page.
  </p>

  {% if stored %}
    <p>
      Already stored:
      {% for name in stored %}<kbd>{{ name }}</kbd>{% if not loop.last %} {% endif %}{% endfor %}
    </p>
  {% endif %}

  <form method="post" action="/setup/2">
    <label>
      Anthropic API key
      <input type="password" name="anthropic_api_key" autocomplete="off" placeholder="sk-ant-...">
    </label>

    <div class="grid">
      <label>
        SMTP host
        <input type="text" name="smtp_host" autocomplete="off" placeholder="smtp.example.com">
      </label>
      <label>
        SMTP port
        <input type="text" name="smtp_port" autocomplete="off" placeholder="587">
      </label>
    </div>

    <div class="grid">
      <label>
        SMTP user
        <input type="text" name="smtp_user" autocomplete="off">
      </label>
      <label>
        SMTP password
        <input type="password" name="smtp_password" autocomplete="off">
      </label>
    </div>

    <button type="submit">Save and continue &rarr;</button>
  </form>
</section>
{% endblock %}
