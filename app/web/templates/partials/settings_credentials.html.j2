{% include "partials/flash_message.html.j2" %}
<h3>Credentials</h3>
<p>API keys and service credentials. Values are encrypted at rest and never displayed after saving.</p>

{# ── Claude API Key ─────────────────────────────────────────────── #}
<article>
  <header>
    <strong>Claude API Key</strong>
    {% if anthropic_configured %}
      <span style="color: var(--pico-color-green-500, green); margin-left: 0.5rem;">Configured</span>
    {% else %}
      <span style="color: var(--pico-color-grey-500, grey); margin-left: 0.5rem;">Not set</span>
    {% endif %}
  </header>
  <form hx-post="/settings/credentials/anthropic" hx-target="#settings-content" hx-swap="innerHTML">
    <label for="anthropic_api_key">API Key</label>
    <input type="password" id="anthropic_api_key" name="api_key"
           placeholder="sk-ant-..." autocomplete="off">
    <small>Enter a new key to replace the current one. The field is always empty for security.</small>
    <button type="submit" class="primary">Save API key</button>
  </form>
</article>

{# ── SMTP Credentials ───────────────────────────────────────────── #}
<article>
  <header>
    <strong>SMTP Credentials</strong>
    {% if smtp_configured %}
      <span style="color: var(--pico-color-green-500, green); margin-left: 0.5rem;">Configured</span>
    {% else %}
      <span style="color: var(--pico-color-grey-500, grey); margin-left: 0.5rem;">Not set</span>
    {% endif %}
  </header>
  <form hx-post="/settings/credentials/smtp" hx-target="#settings-content" hx-swap="innerHTML">
    <div class="grid">
      <label>
        Host
        <input type="text" name="smtp_host" placeholder="smtp.gmail.com" autocomplete="off">
      </label>
      <label>
        Port
        <input type="number" name="smtp_port" placeholder="587" value="587">
      </label>
    </div>
    <label>
      Username
      <input type="text" name="smtp_user" placeholder="you@example.com" autocomplete="off">
    </label>
    <label>
      Password
      <input type="password" name="smtp_password" placeholder="app password" autocomplete="off">
    </label>
    <small>All four fields are required. Enter new values to replace existing credentials.</small>
    <button type="submit" class="primary">Save SMTP credentials</button>
  </form>
</article>
