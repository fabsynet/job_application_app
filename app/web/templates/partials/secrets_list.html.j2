<div id="secrets-list">
  <ul>
  {% for name in known_names %}
    <li>
      <strong>{{ name }}</strong>:
      {% if name in stored_names %}
        &#10003; stored
        <button hx-delete="/settings/secrets/{{ name }}"
                hx-target="#secrets-list"
                hx-swap="outerHTML"
                hx-confirm="Delete {{ name }}?"
                class="outline contrast">
          Delete
        </button>
      {% else %}
        <em>not set</em>
      {% endif %}
    </li>
  {% endfor %}
  {% for name in stored_names %}
    {% if name not in known_names %}
    <li>
      <strong>{{ name }}</strong>: &#10003; stored (custom)
      <button hx-delete="/settings/secrets/{{ name }}"
              hx-target="#secrets-list"
              hx-swap="outerHTML"
              hx-confirm="Delete {{ name }}?"
              class="outline contrast">
        Delete
      </button>
    </li>
    {% endif %}
  {% endfor %}
  </ul>
</div>
