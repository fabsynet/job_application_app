{% include "partials/flash_message.html.j2" %}
<h3>Profile</h3>
<p>Application fields used to auto-fill job submissions. All fields are optional.</p>

<form hx-post="/settings/profile" hx-target="#settings-content" hx-swap="innerHTML">

  {# ── Contact ──────────────────────────────────────────────────── #}
  <details open>
    <summary><strong>Contact Information</strong></summary>
    <div style="padding: 0.5rem 0;">
      <label for="full_name">Full Name</label>
      <input type="text" id="full_name" name="full_name"
             value="{{ profile.full_name or '' }}"
             placeholder="Jane Doe">

      <label for="email">Email</label>
      <input type="email" id="email" name="email"
             value="{{ profile.email or '' }}"
             placeholder="jane@example.com">

      <label for="phone">Phone</label>
      <input type="tel" id="phone" name="phone"
             value="{{ profile.phone or '' }}"
             placeholder="5551234567">

      <label for="address">Address</label>
      <textarea id="address" name="address" rows="2"
                placeholder="123 Main St&#10;City, State ZIP">{{ profile.address or '' }}</textarea>
    </div>
  </details>

  {# ── Work Details ─────────────────────────────────────────────── #}
  <details open>
    <summary><strong>Work Details</strong></summary>
    <div style="padding: 0.5rem 0;">
      <label for="work_authorization">Work Authorization</label>
      <select id="work_authorization" name="work_authorization">
        <option value="">-- Select --</option>
        {% set wa_options = ["US Citizen", "Green Card", "H1B", "OPT/CPT", "Other"] %}
        {% for opt in wa_options %}
        <option value="{{ opt }}" {% if profile.work_authorization == opt %}selected{% endif %}>{{ opt }}</option>
        {% endfor %}
      </select>

      <label for="salary_expectation">Salary Expectation</label>
      <input type="text" id="salary_expectation" name="salary_expectation"
             value="{{ profile.salary_expectation or '' }}"
             placeholder="$80,000-$100,000">

      <label for="years_experience">Years of Experience</label>
      <input type="number" id="years_experience" name="years_experience"
             value="{{ profile.years_experience if profile.years_experience is not none else '' }}"
             min="0" max="99"
             placeholder="5">
    </div>
  </details>

  {# ── Links ────────────────────────────────────────────────────── #}
  <details open>
    <summary><strong>Links</strong></summary>
    <div style="padding: 0.5rem 0;">
      <label for="linkedin_url">LinkedIn URL</label>
      <input type="url" id="linkedin_url" name="linkedin_url"
             value="{{ profile.linkedin_url or '' }}"
             placeholder="https://linkedin.com/in/janedoe">

      <label for="github_url">GitHub URL</label>
      <input type="url" id="github_url" name="github_url"
             value="{{ profile.github_url or '' }}"
             placeholder="https://github.com/janedoe">

      <label for="portfolio_url">Portfolio URL</label>
      <input type="url" id="portfolio_url" name="portfolio_url"
             value="{{ profile.portfolio_url or '' }}"
             placeholder="https://janedoe.dev">
    </div>
  </details>

  <button type="submit" class="primary">Save profile</button>
</form>
