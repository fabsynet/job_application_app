{% extends "base.html.j2" %}
{% block title %}Applied Jobs &mdash; Job Apply{% endblock %}
{% block content %}
<h2>Applied Jobs</h2>
<p>{{ total }} job{{ '' if total == 1 else 's' }} in the applied pipeline.</p>

<div id="banner-slot">
  {% include "applied/_banner.html.j2" %}
</div>

<div id="counts-slot">
  {% include "applied/_counts.html.j2" %}
</div>

<form method="get" action="/applied"
      hx-get="/applied"
      hx-target="#applied-table"
      hx-trigger="change">
  <fieldset role="group">
    <label>
      Status:
      <select name="status" multiple size="5">
        {% for s in default_statuses %}
        <option value="{{ s }}" {% if s in current_status %}selected{% endif %}>{{ s }}</option>
        {% endfor %}
      </select>
    </label>
    <label>
      Source:
      <select name="source" multiple size="5">
        <option value="greenhouse" {% if 'greenhouse' in current_source %}selected{% endif %}>greenhouse</option>
        <option value="lever" {% if 'lever' in current_source %}selected{% endif %}>lever</option>
        <option value="ashby" {% if 'ashby' in current_source %}selected{% endif %}>ashby</option>
        <option value="manual" {% if 'manual' in current_source %}selected{% endif %}>manual</option>
      </select>
    </label>
    <label>
      Sort by:
      <select name="sort_by">
        <option value="submitted_at" {% if current_sort == 'submitted_at' %}selected{% endif %}>Submitted at</option>
        <option value="company" {% if current_sort == 'company' %}selected{% endif %}>Company</option>
        <option value="title" {% if current_sort == 'title' %}selected{% endif %}>Role</option>
        <option value="score" {% if current_sort == 'score' %}selected{% endif %}>Match score</option>
        <option value="status" {% if current_sort == 'status' %}selected{% endif %}>Status</option>
        <option value="source" {% if current_sort == 'source' %}selected{% endif %}>Source</option>
      </select>
    </label>
    <label>
      Direction:
      <select name="sort_dir">
        <option value="desc" {% if current_dir == 'desc' %}selected{% endif %}>Desc</option>
        <option value="asc" {% if current_dir == 'asc' %}selected{% endif %}>Asc</option>
      </select>
    </label>
  </fieldset>
</form>

<div id="applied-table">
  {% include "applied/_table.html.j2" %}
</div>
{% endblock %}
